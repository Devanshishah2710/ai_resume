# Copy this file to .env.local and fill in your Supabase project values
# Get these from: https://supabase.com/dashboard/project/<your-project>/settings/api
# Set this to false to hide the "Continue with Google" button (e.g. before the
# Google provider is configured in Supabase Auth). It is enabled by default.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
# VITE_ENABLE_GOOGLE_AUTH=false
